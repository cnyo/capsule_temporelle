# Environment Configuration
# Copiez ce fichier en .env et ajustez les valeurs selon votre environnement

# Environment: dev ou prod
NODE_ENV=production

# Spring Boot Profile: dev ou prod
SPRING_PROFILES_ACTIVE=prod

# Backend - Chemin du fichier de données
CAPSULE_FILE_PATH=/app/data/capsule.json

# CORS - Origines autorisées (séparées par des virgules)
# Ajoutez l'URL de votre frontend déployé sur Dokploy
# Exemple: CORS_ALLOWED_ORIGINS=https://votreapp.dokploy.com,http://localhost:4200
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://127.0.0.1:4200,http://localhost:9004,http://127.0.0.1:9004

# Frontend - URL du backend (pour le proxy nginx)
# En local avec docker-compose: http://backend:8080
# Sur Dokploy: URL du service backend (ex: https://backend.votredomaine.com ou http://nom-service-backend:8080)
BACKEND_URL=http://backend:8080

# Ports (optionnel - utilisé par docker-compose)
# BACKEND_PORT=8080
# FRONTEND_PORT=80
